<!DOCTYPE html>
<!-- Generated from .claude/skills/{{ skill_name }}/mockup.yaml — edit YAML, not this file. -->
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Skill anatomy — {{ skill_name }}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="style.css">
<link rel="stylesheet" href="https://unpkg.com/aos@2.3.4/dist/aos.css">
<style>
.diagram-frame {
  background: var(--bg-glass);
  backdrop-filter: blur(12px);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-xl);
  padding: 28px 24px;
  overflow-x: auto;
}
.diagram-frame svg { display: block; width: 100%; height: auto; max-width: 100%; }

.zone { rx: 18; opacity: 0.07; }
.zone-intake        { fill: var(--layer-intake); }
.zone-logic         { fill: var(--layer-logic); }
.zone-orchestration { fill: var(--layer-orchestration); }
.zone-safety        { fill: var(--layer-safety); }
.zone-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  fill-opacity: 0.7;
}

.comp-label  { font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 600; fill: var(--text-primary); text-anchor: middle; pointer-events: none; }
.comp-sub    { font-family: 'JetBrains Mono', monospace; font-size: 9.5px; fill: var(--text-secondary); text-anchor: middle; pointer-events: none; text-transform: uppercase; letter-spacing: 0.08em; }
.comp-bullet { font-family: 'Inter', sans-serif; font-size: 11px; fill: var(--text-secondary); pointer-events: none; }

.phase-num   { font-family: 'JetBrains Mono', monospace; font-size: 11px; font-weight: 600; fill: var(--cyber-cyan); text-anchor: end; pointer-events: none; }
.phase-name  { font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 600; fill: var(--text-primary); pointer-events: none; }
.phase-sub   { font-family: 'Inter', sans-serif; font-size: 10.5px; fill: var(--text-secondary); pointer-events: none; }

.flow-line       { stroke: rgba(148, 163, 184, 0.5); stroke-width: 1.5; fill: none; stroke-dasharray: 5 4; }
.flow-line-solid { stroke: rgba(148, 163, 184, 0.8); stroke-width: 1.5; fill: none; }
.flow-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 9px;
  fill: var(--text-muted);
  text-anchor: middle;
  letter-spacing: 0.05em;
}

.callout {
  margin-top: 22px;
  padding: 18px 22px;
  background: var(--bg-glass);
  border-left: 3px solid var(--cyber-cyan);
  border-radius: var(--radius-md);
  font-size: 13px;
  color: var(--text-secondary);
  line-height: 1.7;
}
.callout strong { color: var(--text-primary); }

.kpi-strip {
  margin-top: 20px;
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 10px;
}
@media (max-width: 800px) { .kpi-strip { grid-template-columns: repeat(3, 1fr); } }
@media (max-width: 480px) { .kpi-strip { grid-template-columns: repeat(2, 1fr); } }
.kpi-tile {
  background: var(--bg-glass);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-md);
  padding: 14px 16px;
  text-align: left;
}
.h-page-tight {
  font-size: clamp(20px, 2.4vw, 26px);
  font-weight: 600;
  letter-spacing: -0.015em;
  line-height: 1.25;
}

.kpi-tile-headline {
  font-size: 14px;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: -0.01em;
  line-height: 1.35;
  margin-bottom: 6px;
}
.kpi-tile-support {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10.5px;
  color: var(--text-muted);
  letter-spacing: 0.04em;
  line-height: 1.4;
}
.kpi-strip > .kpi-tile:nth-child(6n+1) { border-top: 2px solid var(--layer-intake); }
.kpi-strip > .kpi-tile:nth-child(6n+2) { border-top: 2px solid var(--layer-logic); }
.kpi-strip > .kpi-tile:nth-child(6n+3) { border-top: 2px solid var(--cyber-blue); }
.kpi-strip > .kpi-tile:nth-child(6n+4) { border-top: 2px solid var(--layer-safety); }
.kpi-strip > .kpi-tile:nth-child(6n+5) { border-top: 2px solid var(--cyber-cyan); }
.kpi-strip > .kpi-tile:nth-child(6n)   { border-top: 2px solid var(--layer-intake); }

.feat-section { margin-top: 28px; }

.feat-cat { margin-top: 22px; }
.feat-cat:first-child { margin-top: 0; }

.feat-cat-head {
  display: flex; align-items: baseline; gap: 12px;
  margin-bottom: 10px;
  padding-bottom: 8px;
  border-bottom: 1px dashed var(--border-subtle);
}
.feat-cat-eyebrow {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10.5px;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  font-weight: 600;
}
.feat-cat-sub {
  font-size: 12.5px;
  color: var(--text-muted);
}

.feat-cat.cat-rigor      .feat-cat-eyebrow { color: var(--layer-logic); }
.feat-cat.cat-guardrails .feat-cat-eyebrow { color: var(--layer-safety); }
.feat-cat.cat-tradecraft .feat-cat-eyebrow { color: var(--cyber-blue); }

.feat-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
  gap: 10px;
}

.feat-card {
  background: var(--bg-glass);
  backdrop-filter: blur(12px);
  border: 1px solid var(--border-subtle);
  border-left: 3px solid var(--cyber-cyan);
  border-radius: var(--radius-md);
  padding: 14px 14px 12px;
  transition: all 0.2s ease;
  display: flex; flex-direction: column; gap: 4px;
}
.feat-card:hover {
  transform: translateY(-2px);
  border-color: var(--border-medium);
}

.cat-rigor .feat-card { border-left-color: var(--layer-logic); }
.cat-rigor .feat-card .feat-icon { color: var(--layer-logic); }
.cat-rigor .feat-card:hover { box-shadow: 0 6px 24px var(--glow-emerald); }

.cat-guardrails .feat-card { border-left-color: var(--layer-safety); }
.cat-guardrails .feat-card .feat-icon { color: var(--layer-safety); }
.cat-guardrails .feat-card:hover { box-shadow: 0 6px 24px var(--glow-purple); }

.cat-tradecraft .feat-card { border-left-color: var(--cyber-blue); }
.cat-tradecraft .feat-card .feat-icon { color: var(--cyber-blue); }
.cat-tradecraft .feat-card:hover { box-shadow: 0 6px 24px var(--glow-blue); }

.feat-eyebrow {
  display: flex; align-items: center; gap: 8px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  color: var(--text-muted);
  letter-spacing: 0.1em;
  text-transform: uppercase;
}
.feat-num {
  width: 22px; height: 22px;
  border-radius: 6px;
  background: var(--bg-elevated);
  display: inline-flex; align-items: center; justify-content: center;
  font-size: 10px;
  color: var(--text-secondary);
  border: 1px solid var(--border-subtle);
}
.feat-title {
  font-size: 13px;
  font-weight: 600;
  letter-spacing: -0.01em;
  color: var(--text-primary);
  line-height: 1.3;
}
.feat-desc {
  font-size: 11.5px;
  color: var(--text-secondary);
  line-height: 1.4;
}
.feat-icon {
  width: 28px; height: 28px;
  border-radius: 7px;
  display: flex; align-items: center; justify-content: center;
  background: var(--bg-elevated);
  border: 1px solid var(--border-subtle);
  color: var(--cyber-cyan);
  margin-bottom: 4px;
}
.feat-icon svg { width: 16px; height: 16px; }

.feat-closer {
  margin-top: 18px;
  padding: 14px 18px;
  background: var(--bg-glass);
  border: 1px solid var(--border-medium);
  border-radius: var(--radius-md);
  font-size: 13px;
  color: var(--text-secondary);
  text-align: center;
}
.feat-closer strong { color: var(--text-primary); }

</style>
</head>
<body>

<nav class="nav">
  <div class="nav-inner">
    <a class="logo" href="index.html"><span class="logo-mark"></span><span>agent-basics</span></a>
    <ul class="nav-links">
      <li><a href="index.html">Home</a></li>
      <li><a href="architecture.html">Architecture</a></li>
      <li><a href="system.html">System</a></li>
      <li><a href="catalog.html" class="active">Catalog</a></li>
      <li><a href="flow.html">Flow</a></li>
      <li><a href="status.html">Status</a></li>
      <li><a href="roadmap.html">Roadmap</a></li>
    </ul>
  </div>
</nav>

<main>

<section class="page">
  <div class="page-head" data-aos="fade-up">
    <span class="eyebrow">{{ page.eyebrow_prefix }} <code>{{ page.eyebrow_code }}</code></span>
    <h1 class="h-page-tight">{{ page.title }}</h1>
    <p class="lede">{{ page.lede }}</p>
  </div>

  <div class="kpi-strip" data-aos="fade-up" data-aos-delay="40">
    {%- for tile in kpi_tiles %}
    <div class="kpi-tile">
      <div class="kpi-tile-headline">{{ tile.headline }}</div>
      <div class="kpi-tile-support">{{ tile.support }}</div>
    </div>
    {%- endfor %}
  </div>

  <div class="diagram-frame" style="margin-top:22px;" data-aos="fade-up" data-aos-delay="80">
{{ diagram_svg }}
  </div>

  <section class="feat-section" data-aos="fade-up" data-aos-delay="120">
    {%- for group in capability_groups %}

    <div class="feat-cat cat-{{ group.id }}">
      <div class="feat-cat-head">
        <div class="feat-cat-eyebrow">{{ group.label }}</div>
        <div class="feat-cat-sub">{{ group.sub }}</div>
      </div>
      <div class="feat-grid">
        {%- for card in group.cards %}

        <div class="feat-card">
          <div class="feat-icon" aria-hidden="true">
            {{ ICONS[card.icon] | safe }}
          </div>
          <div class="feat-title">{{ card.title }}</div>
          <div class="feat-desc">{{ card.desc }}</div>
        </div>
        {%- endfor %}

      </div>
    </div>
    {%- endfor %}

  </section>

</section>

</main>

<footer>agent-basics — design pattern catalogue · MIT</footer>

<script src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>
<script>AOS.init({duration:600, once:true, offset:60});</script>
</body>
</html>
